{
    "name": "form-renderer",
    "author": "Zaki Hanafiah <zaki@zakhov.com>",
    "version": "0.1.0",
    "private": true,
    "dependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.3.0",
        "@types/react": "^18.3.28",
        "@types/react-dom": "^18.3.7",
        "antd": "^5.29.3",
        "craco-antd": "^2.0.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-json-pretty": "^2.2.0",
        "react-scripts": "5.0.1",
        "typescript": "^5.9.3",
        "web-vitals": "^5.1.0"
    },
    "scripts": {
        "start": "craco start",
        "build": "craco build",
        "test": "craco test",
        "prettify": "prettier --write src/**/*.ts{,x}",
        "eslint": "tsc --noEmit && eslint src/**/*.ts{,x}",
        "eject": "react-scripts eject",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,ts,tsx}": [
            "pretty-quick --staged",
            "eslint --quiet --fix",
            "npm test -- --bail --findRelatedTests --watchAll=false --passWithNoTests"
        ]
    },
    "eslintConfig": {
        "extends": [
            "react-app",
            "react-app/jest"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@craco/craco": "^7.1.0",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "eslint-config-airbnb": "^19.0.4",
        "eslint-config-airbnb-typescript": "^18.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.5",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.1",
        "pretty-quick": "^4.2.2",
        "tsconfig-paths-webpack-plugin": "^4.2.0"
    },
    "overrides": {
        "minimatch": "^10.0.0",
        "glob": "^11.0.0",
        "nth-check": "^2.1.1",
        "postcss": "^8.4.31",
        "svgo": "^3.0.0",
        "rimraf": "^6.0.0",
        "bfj": "^9.1.3",
        "webpack-dev-server": "4.6.0"
    }
}
